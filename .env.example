# Backend Environment Variables
# CRITICAL: Change all values before deployment

# Database
DATABASE_URL=postgresql://docmind_user:secure_password_here@localhost:5432/docmind_db
# For local development with SQLite: sqlite:///./docmind.db

# Redis
REDIS_URL=redis://:secure_password_here@localhost:6379/0

# JWT Secret - MUST be changed in production! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secure_secret_key_min_32_chars_here_12345

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Frontend Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database credentials for docker-compose
DB_USER=docmind_user
DB_PASSWORD=secure_password_here_change_in_production
DB_NAME=docmind_db
REDIS_PASSWORD=secure_password_here_change_in_production

DATABASE_URL=postgresql://docmind_user:secure_password_here@localhost:5432/docmind_db
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=your-super-secret-key-change-this-in-production-use-random-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Groq Configuration (Free & Open Source)
# Get your free API key from https://console.groq.com
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Available Groq Models:
# - llama-3.3-70b-versatile (recommended, best overall)
# - llama-3.1-70b-versatile (also good)
# - mixtral-8x7b-32768 (DEPRECATED - DO NOT USE)
# - llama2-70b-4096 (deprecated)
# - gemma-7b-it (smaller, faster)

EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=512
CHUNK_OVERLAP=50

AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=docmind-documents
AWS_REGION=us-east-1

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

LOG_LEVEL=INFO
